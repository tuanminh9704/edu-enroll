  "description": "API hệ thống tuyển sinh Trung tâm ngôn ngữ Apex",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
